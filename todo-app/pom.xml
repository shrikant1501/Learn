<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
             https://maven.apache.org/xsd/maven-4.0.0.xsd">

    <modelVersion>4.0.0</modelVersion>

    <!--
        PARENT: Spring Boot's parent POM.
        This gives us:
          - Pre-configured dependency versions (no version conflicts)
          - Default plugin configuration
          - Common properties like Java version handling
        Think of it as inheriting from a well-maintained base configuration.
    -->
    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>3.2.5</version>
        <relativePath/>
    </parent>

    <!--
        PROJECT COORDINATES: The unique identity of this project in the Maven world.
        groupId    → Your organization/domain (reversed), like a Java package root
        artifactId → The name of this specific project/module
        version    → Current version. SNAPSHOT means "in development, not released"
        packaging  → jar = self-contained executable JAR (Spring Boot default)
    -->
    <groupId>com.learnjava</groupId>
    <artifactId>todo-app</artifactId>
    <version>0.0.1-SNAPSHOT</version>
    <packaging>jar</packaging>

    <name>todo-app</name>
    <description>Spring Boot Todo Application - Learning Project</description>

    <properties>
        <!--
            Java version. Spring Boot 3.x requires Java 17+.
            We use 21 (current LTS). You have Java 25 installed, which is
            forward-compatible with Java 21 compiled bytecode.
            Java 21 is what you'll encounter in most enterprise environments today.
        -->
        <java.version>21</java.version>
        <!--
            We pin the Lombok version explicitly here so we can reference it
            in the annotationProcessorPaths section of the compiler plugin.
            Spring Boot's parent POM manages Lombok's version, and we can
            read that managed version via ${lombok.version}.
        -->
        <!--
            Lombok 1.18.38 is the latest release with improved Java 23/24/25 compatibility.
            Earlier versions fail with TypeTag::UNKNOWN errors because Lombok
            uses internal javac APIs that changed in Java 23+.
        -->
        <lombok.version>1.18.38</lombok.version>
        <!--
            MapStruct version pinned explicitly — not managed by Spring Boot's BOM.
            1.5.x is the current stable series and supports Spring Boot 3 / Jakarta EE.
        -->
        <mapstruct.version>1.5.5.Final</mapstruct.version>
    </properties>

    <dependencies>

        <!--
            SPRING BOOT WEB STARTER
            This single dependency pulls in everything needed for a REST API:
              - Spring MVC (the web framework)
              - Tomcat (the embedded web server — no separate server needed)
              - Jackson (JSON serialization/deserialization)
            This is the magic of "starters" — they are curated dependency bundles.
        -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
        </dependency>

        <!--
            LOMBOK
            A compile-time annotation processor that generates boilerplate code:
              - @Getter / @Setter → generates getters and setters
              - @NoArgsConstructor → generates no-arg constructor
              - @AllArgsConstructor → generates all-args constructor
              - @Builder → implements the Builder pattern
              - @Data → combines @Getter, @Setter, @EqualsAndHashCode, @ToString
            Without Lombok, every model class would have 50+ lines of boilerplate.
            With Lombok, it's clean and focused on the data, not the plumbing.
            "provided" scope means it's only needed at compile time, not at runtime.
        -->
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <optional>true</optional>
        </dependency>

        <!--
            SPRING BOOT TEST STARTER
            Everything needed for testing:
              - JUnit 5 (the test framework)
              - Mockito (mocking framework)
              - Spring Test (integration testing utilities)
            "test" scope means this is ONLY available during test compilation and execution.
            It will NOT be in your production JAR.
        -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>

        <!-- spring-security-test: provides @WithMockUser, SecurityMockMvcRequestPostProcessors,
             and other test utilities for Spring Security integration tests.
             Without this, @WithMockUser annotation is not available. -->
        <dependency>
            <groupId>org.springframework.security</groupId>
            <artifactId>spring-security-test</artifactId>
            <scope>test</scope>
        </dependency>

        <!-- Spring Data JPA: ORM support, JpaRepository, @Transactional management -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-data-jpa</artifactId>
        </dependency>

        <!-- H2: in-memory relational database — used for local dev and unit tests.
             Kept as 'runtime' scope so it's available during test execution.
             When running with Docker (PostgreSQL), H2 is still used by unit tests
             via the default application.properties — ensuring fast test runs. -->
        <dependency>
            <groupId>com.h2database</groupId>
            <artifactId>h2</artifactId>
            <scope>runtime</scope>
        </dependency>

        <!-- PostgreSQL JDBC Driver — required when the app runs against a real PostgreSQL DB.
             'runtime' scope: we only need it at runtime, not at compile time.
             The JPA/JDBC API contracts are compile-time; the driver is runtime.
             This is activated when SPRING_PROFILES_ACTIVE=docker or when running
             with application-docker.properties. -->
        <dependency>
            <groupId>org.postgresql</groupId>
            <artifactId>postgresql</artifactId>
            <scope>runtime</scope>
        </dependency>

        <!-- Bean Validation (JSR-380): @NotBlank, @Size, @NotNull, @Email, etc.
             Bundles Hibernate Validator (the reference implementation) + Jakarta Validation API.
             This is the standard way to declare input constraints in Spring Boot. -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-validation</artifactId>
        </dependency>

        <!-- SpringDoc OpenAPI: auto-generates OpenAPI 3 spec from Spring MVC code.
             Serves Swagger UI at /swagger-ui.html and the raw spec at /v3/api-docs.
             Use this for Spring Boot 3.x — NOT Springfox (incompatible with Boot 3). -->
        <dependency>
            <groupId>org.springdoc</groupId>
            <artifactId>springdoc-openapi-starter-webmvc-ui</artifactId>
            <version>2.5.0</version>
        </dependency>

        <!-- Spring Security: authentication, authorization, filter chain -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-security</artifactId>
        </dependency>

        <!-- JJWT: Java JWT library for generating and validating JWT tokens.
             Three jars needed: api (the interfaces), impl (the implementation),
             and jackson (for JSON serialization of claims). -->
        <dependency>
            <groupId>io.jsonwebtoken</groupId>
            <artifactId>jjwt-api</artifactId>
            <version>0.12.5</version>
        </dependency>
        <dependency>
            <groupId>io.jsonwebtoken</groupId>
            <artifactId>jjwt-impl</artifactId>
            <version>0.12.5</version>
            <scope>runtime</scope>
        </dependency>
        <dependency>
            <groupId>io.jsonwebtoken</groupId>
            <artifactId>jjwt-jackson</artifactId>
            <version>0.12.5</version>
            <scope>runtime</scope>
        </dependency>

        <!--
            MAPSTRUCT
            The mapstruct jar provides the annotations we use in our mapper interface
            (@Mapper, @Mapping, @MappingTarget etc.) and the API types MapStruct needs
            at compile time. It has NO runtime reflection — the generated code is
            plain Java, so there is zero overhead over hand-written mappers.
        -->
        <dependency>
            <groupId>org.mapstruct</groupId>
            <artifactId>mapstruct</artifactId>
            <version>${mapstruct.version}</version>
        </dependency>

    </dependencies>

    <build>
        <plugins>
            <!--
                MAVEN COMPILER PLUGIN
                Explicitly configures Java compilation.
                We must declare Lombok as an annotation processor here because
                Lombok works at compile time — it hooks into the Java compiler (javac)
                to generate code (getters, builders, loggers, etc.) BEFORE the compiler
                runs its normal type-checking pass.
                Without this, on modern Java versions, the compiler never invokes
                Lombok and it produces "cannot find symbol" errors for generated code.
            -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <configuration>
                    <!--
                        Java 23+ locks down internal JDK APIs by default (JEP 471).
                        Lombok uses sun.tools.javac internals to do its code generation.
                        We must open these packages to the unnamed module so Lombok
                        can access them at compile time. Without this, we get the
                        ExceptionInInitializerError: TypeTag::UNKNOWN error on Java 23+.
                        This is a compile-time-only flag — it has no effect at runtime.
                    -->
                    <compilerArgs>
                        <arg>-J--add-opens=jdk.compiler/com.sun.tools.javac.code=ALL-UNNAMED</arg>
                        <arg>-J--add-opens=jdk.compiler/com.sun.tools.javac.comp=ALL-UNNAMED</arg>
                        <arg>-J--add-opens=jdk.compiler/com.sun.tools.javac.file=ALL-UNNAMED</arg>
                        <arg>-J--add-opens=jdk.compiler/com.sun.tools.javac.main=ALL-UNNAMED</arg>
                        <arg>-J--add-opens=jdk.compiler/com.sun.tools.javac.model=ALL-UNNAMED</arg>
                        <arg>-J--add-opens=jdk.compiler/com.sun.tools.javac.parser=ALL-UNNAMED</arg>
                        <arg>-J--add-opens=jdk.compiler/com.sun.tools.javac.processing=ALL-UNNAMED</arg>
                        <arg>-J--add-opens=jdk.compiler/com.sun.tools.javac.tree=ALL-UNNAMED</arg>
                        <arg>-J--add-opens=jdk.compiler/com.sun.tools.javac.util=ALL-UNNAMED</arg>
                        <arg>-J--add-opens=jdk.compiler/com.sun.tools.javac.jvm=ALL-UNNAMED</arg>
                    </compilerArgs>
                    <annotationProcessorPaths>
                        <!--
                            ORDER IS CRITICAL:
                            1. Lombok must run FIRST — it generates the getters/setters/builders
                               that MapStruct needs to read when generating mapping code.
                            2. lombok-mapstruct-binding ensures Lombok and MapStruct
                               annotation processors are coordinated correctly.
                            3. MapStruct runs LAST — it reads Lombok-generated code
                               to produce the final mapper implementation.
                            If Lombok and MapStruct run in the wrong order, MapStruct
                            will see classes WITHOUT getters and generate broken mappers.
                        -->
                        <path>
                            <groupId>org.projectlombok</groupId>
                            <artifactId>lombok</artifactId>
                            <version>${lombok.version}</version>
                        </path>
                        <path>
                            <!--
                                lombok-mapstruct-binding: a tiny bridge that tells the
                                Java compiler to run Lombok's processor before MapStruct's.
                                Without this, the order is non-deterministic and MapStruct
                                may see Lombok-annotated classes before Lombok has processed them.
                            -->
                            <groupId>org.projectlombok</groupId>
                            <artifactId>lombok-mapstruct-binding</artifactId>
                            <version>0.2.0</version>
                        </path>
                        <path>
                            <groupId>org.mapstruct</groupId>
                            <artifactId>mapstruct-processor</artifactId>
                            <version>${mapstruct.version}</version>
                        </path>
                    </annotationProcessorPaths>
                </configuration>
            </plugin>

            <!--
                MAVEN SUREFIRE PLUGIN
                Configures how Maven runs unit tests.
                On Java 23+, ByteBuddy (used by Mockito to create mock subclasses) cannot
                instrument java.lang.Object and core JDK classes unless we explicitly open
                the relevant internal packages to the unnamed module at test runtime.
                Without these argLine settings, @MockBean on concrete @Service classes like
                JwtService throws "Could not modify all classes" and tests fail to load context.
            -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <configuration>
                    <argLine>
                        --add-opens java.base/java.lang=ALL-UNNAMED
                        --add-opens java.base/java.util=ALL-UNNAMED
                        --add-opens java.base/java.lang.reflect=ALL-UNNAMED
                    </argLine>
                </configuration>
            </plugin>

            <!--
                SPRING BOOT MAVEN PLUGIN
                This plugin does one critical thing: it packages your application
                into a "fat JAR" (also called an uber-JAR or executable JAR).
                A fat JAR contains:
                  - Your compiled code
                  - ALL dependencies (including Tomcat)
                  - A manifest pointing to the main class
                Result: you can run your entire app with: java -jar todo-app.jar
                This is how Spring Boot apps are deployed in production.
            -->
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
                <configuration>
                    <!--
                        Exclude Lombok from the final JAR.
                        Lombok only does its work at compile time (generating code).
                        The generated code is already in the bytecode.
                        Including Lombok at runtime would waste space and could cause issues.
                    -->
                    <excludes>
                        <exclude>
                            <groupId>org.projectlombok</groupId>
                            <artifactId>lombok</artifactId>
                        </exclude>
                    </excludes>
                </configuration>
            </plugin>
        </plugins>
    </build>

</project>
